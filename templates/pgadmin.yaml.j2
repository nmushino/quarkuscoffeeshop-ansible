apiVersion: postgres-operator.crunchydata.com/v1beta1
kind: PGAdmin
metadata:
  name: pgadmin4
  namespace: {{ project_namespace }}
spec:
  dataVolumeClaimSpec:
    accessModes:
      - ReadWriteOnce
    resources:
      requests:
        storage: 1Gi
  serverGroups:
  users:
  - username: {{ pgadmin_setup_email }}
    role: User
    passwordRef:
      name: pgadmin4-secret
      key: password
  serverGroups:
    - name: Crunchy Postgres for Kubernetes
      postgresClusterSelector:
        matchLabels:
          postgres-operator.crunchydata.com/cluster: coffeeshopdb
  podTemplate:
  metadata: {}
  spec:
    volumes:
      - name: pgadmin4-json
        configMap:
          name: pgadmin4-servers
          items:
            - key: pgadmin4.json
              path: pgadmin4.json
    containers:
      - name: pgadmin
        volumeMounts:
          - name: servers-json
            mountPath: /pgadmin4/pgadmin4.json
            subPath: pgadmin4.json
---
apiVersion: v1
kind: Secret
metadata:
  name: pgadmin4-secret
  namespace: {{ project_namespace }}
type: Opaque
stringData:
  email: {{ pgadmin_setup_email }}
  password: {{ pgadmin_default_password }}
---
apiVersion: v1
kind: Service
metadata:
  name: pgadmin4
  namespace: {{ project_namespace }}
spec:
  selector:
    postgres-operator.crunchydata.com/role: pgadmin
  ports:
    - port: 80
      targetPort: 5050
      protocol: TCP
      name: http
---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: pgadmin4
  namespace: {{ project_namespace }}
spec:
  to:
    kind: Service
    name: pgadmin4
  port:
    targetPort: http
  tls:
    termination: edge
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: pgadmin4-servers
  namespace: {{ project_namespace }}
data:
  pgadmin4.json: |
    {
      "Servers": {
        "1": {
          "Name": "coffeeshop",
          "Group": "Servers",
          "Host": "coffeeshopdb-primary.quarkuscoffeeshop-demo.svc",
          "Port": 5432,
          "MaintenanceDB": "coffeeshopdb",
          "Username": "coffeeshopadmin",
          "SSLMode": "prefer"
        }
      }
    }