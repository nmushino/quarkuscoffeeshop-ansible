apiVersion: apps/v1
kind: Deployment
metadata:
  name: pgadmin4
  namespace: {{ project_namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: pgadmin4
  template:
    metadata:
      labels:
        app: pgadmin4
    spec:
      containers:
        - name: pgadmin4
          image: dpage/pgadmin4:latest
          env:
            - name: PGADMIN_DEFAULT_EMAIL
              value: {{ pgadmin_setup_email }}
            - name: PGADMIN_DEFAULT_PASSWORD
              value: {{ pgadmin_default_password }}
          ports:
            - containerPort: 80
          volumeMounts:
            - name: pgadmin-data
              mountPath: /var/lib/pgadmin
      volumes:
        - name: pgadmin-data
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: pgadmin4
  namespace: {{ project_namespace }}
spec:
  selector:
    app: pgadmin4
  ports:
    - port: 80
      targetPort: 80
      protocol: TCP
      name: http
---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: pgadmin4
  namespace: {{ project_namespace }}
spec:
  to:
    kind: Service
    name: pgadmin4
  port:
    targetPort: http
  tls:
    termination: edge